{
  "name": "SmartShare",
  "short_name": "SmartShare App", 
  "start_url": "./",
  "display": "standalone",
  "background_color": "#0b1311",
  "theme_color": "#090d0c",
  "icons": [
    {
      "src": "appicon.png",
      "sizes": "192x192 512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/share-receive/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["*/*", "image/*", "video/*", "audio/*", "application/*", "text/*"]
        }
      ]
    }
  }
}
