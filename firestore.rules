rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 SECURE: SmartShare Link Validation 
    match /links/{linkId} {
      // Anyone can read a link to download a file
      allow read: if true;

      // Ensures only properly formatted files are added to the database
      allow create: if request.resource.data.keys().hasAll(['name', 'size', 'type', 'url', 'storagePath', 'expiresAt', 'createdAt', 'ownerId'])
                    && request.resource.data.size is number
                    && request.resource.data.size <= 104857600; // Limits DB entries to 100MB

      // Allows users to extend time (update) but prevents them from changing the owner
      allow update: if request.resource.data.ownerId == resource.data.ownerId;

      // Allows deletion (app automatically deletes expired or one-time links)
      allow delete: if true;
    }

    // 🎨 Rules for application styling/settings (SmartShare)
    match /settings/{settingId} {
      // Anyone can read the global theme styles to render the app with your customizations
      allow read: if true;
      
      // Permit writing to the 'style' document and validate its exact schema to ensure stability
      allow write: if settingId == 'style' 
                   && request.resource.data.keys().hasAll([
                        'accentColor', 'panelOpacity', 'panelBlur', 
                        'inputOpacity', 'inputBlur', 'dropOpacity', 
                        'dropBlur', 'lightCardBase', 'darkCardBase',
                        'lightBgColor', 'darkBgColor', 'lightCardColor', 'darkCardColor'
                      ])
                   && request.resource.data.keys().size() == 13
                   && request.resource.data.accentColor is string
                   && request.resource.data.panelOpacity is int
                   && request.resource.data.panelBlur is int
                   && request.resource.data.inputOpacity is int
                   && request.resource.data.inputBlur is int
                   && request.resource.data.dropOpacity is int
                   && request.resource.data.dropBlur is int
                   && request.resource.data.lightCardBase is string
                   && request.resource.data.darkCardBase is string
                   && request.resource.data.lightBgColor is string
                   && request.resource.data.darkBgColor is string
                   && request.resource.data.lightCardColor is string
                   && request.resource.data.darkCardColor is string;
    }
    
    // 🔒 SECURE: Protects your Docukeep App Data from hackers (UNCHANGED)
    match /folders/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /users/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
